</main>

<?!= include('script'); ?>

<!-- ══════════════════════════════════════════════
     SCRIPTS FONCTIONNELS — profile modal, avatar, thème, etc.
     ⚠️ Plus de déclaration de USER_FIRST_NAME / USER_EMAIL ici
══════════════════════════════════════════════ -->
<script>
function loadAvatarGalleryModal() {
  const gallery = document.getElementById('avatarGalleryModal');
  if (!gallery || gallery.children.length > 0) return;
  google.script.run
    .withSuccessHandler(function(presets) {
      google.script.run
        .withSuccessHandler(function(currentAvatar) {
          gallery.innerHTML = '';
          presets.forEach((url) => {
            const option = document.createElement('div');
            option.className = 'avatar-option' + (url === currentAvatar ? ' selected' : '');
            option.innerHTML = `<img src="${url}" alt="Avatar option">`;
            option.addEventListener('click', function() { changeAvatar(this, url); });
            gallery.appendChild(option);
          });
        })
        .getUserAvatar();
    })
    .withFailureHandler(function(error) { console.error('Error loading avatar gallery:', error); })
    .getAvatarPresets();
}

function changeAvatar(element, url) {
  showToast('Changement d\'avatar...', 'info');
  document.querySelectorAll('#avatarGalleryModal .avatar-option').forEach(opt => opt.classList.remove('selected'));
  element.classList.add('selected');
  document.getElementById('profile-avatar-img').src = url;
  const headerPic = document.querySelector('.profile-pic');
  if (headerPic) headerPic.src = url;
  google.script.run
    .withSuccessHandler(function(result) {
      if (result.success) { showToast('Avatar mis à jour !', 'success'); }
      else { showToast('Erreur: ' + result.error, 'error'); loadCurrentAvatar(); }
    })
    .withFailureHandler(function(error) { showToast('Erreur: ' + error.message, 'error'); loadCurrentAvatar(); })
    .updateUserAvatar(url);
}

function loadCurrentAvatar() {
  google.script.run
    .withSuccessHandler(function(avatarUrl) {
      if (!avatarUrl) return;
      const profilePic  = document.querySelector('.profile-pic');
      const modalAvatar = document.getElementById('profile-avatar-img');
      if (profilePic)  profilePic.src  = avatarUrl;
      if (modalAvatar) modalAvatar.src = avatarUrl;
    })
    .withFailureHandler(function(error) { console.error('Failed to load avatar:', error); })
    .getUserAvatar();
}

document.addEventListener('DOMContentLoaded', function() {
  const greeting = document.getElementById('user-greeting');
  if (greeting) greeting.textContent = 'Hey, ' + USER_FIRST_NAME + ' !';
  updateProfileModal();
  const profilePic = document.querySelector('.profile-pic-container');
  if (profilePic) {
    profilePic.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openProfileModal(); }
    });
  }
});

function openProfileModal() {
  const modal = document.getElementById('profile-modal');
  if (modal) { modal.classList.add('active'); document.body.style.overflow = 'hidden'; }
}
function closeProfileModal() {
  const modal = document.getElementById('profile-modal');
  if (modal) { modal.classList.remove('active'); document.body.style.overflow = ''; }
}
document.getElementById('profile-modal')?.addEventListener('click', function(e) { if (e.target === this) closeProfileModal(); });
document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeProfileModal(); });

function handleNameKeydown(event) {
  if (event.key === 'Enter') { event.preventDefault(); saveNameEdit(); }
  if (event.key === 'Escape') cancelNameEdit();
}
var isSavingName = false;
function toggleNameEdit() {
  const nameInput = document.getElementById('profile-name-input');
  if (nameInput.style.display === 'block') saveNameEdit(); else enableNameEdit();
}
function enableNameEdit() {
  const nameDisplay = document.getElementById('profile-name-display');
  const nameInput   = document.getElementById('profile-name-input');
  if (nameDisplay && nameInput) {
    nameInput.value = nameDisplay.textContent;
    nameDisplay.style.display = 'none';
    nameInput.style.display = 'block';
    setTimeout(() => { nameInput.focus(); nameInput.select(); }, 10);
  }
}
function cancelNameEdit() {
  const nameDisplay = document.getElementById('profile-name-display');
  const nameInput   = document.getElementById('profile-name-input');
  if (nameDisplay && nameInput) { nameInput.style.display = 'none'; nameDisplay.style.display = 'block'; }
}
function saveNameEdit() {
  if (isSavingName) return;
  const nameInput   = document.getElementById('profile-name-input');
  const nameDisplay = document.getElementById('profile-name-display');
  const newName = nameInput.value.trim();
  const oldName = nameDisplay.textContent;
  if (!newName) { showToast('Le prénom ne peut pas être vide', 'error'); cancelNameEdit(); return; }
  if (newName === oldName) { cancelNameEdit(); return; }
  isSavingName = true;
  showToast('Mise à jour...', 'info');
  google.script.run
    .withSuccessHandler(function(result) {
      isSavingName = false;
      if (result.success) {
        USER_FIRST_NAME = result.profile.firstName;
        nameDisplay.textContent = result.profile.firstName;
        const greeting = document.getElementById('user-greeting');
        if (greeting) greeting.textContent = 'Hey, ' + result.profile.firstName + ' !';
        cancelNameEdit();
        showToast('Prénom changé avec succès !', 'success');
      } else { showToast('Erreur: ' + result.error, 'error'); cancelNameEdit(); }
    })
    .withFailureHandler(function(error) { isSavingName = false; showToast('Erreur serveur: ' + error.message, 'error'); cancelNameEdit(); })
    .updateUserFirstName(newName);
}

function changeTheme(themeName) {
  showToast('Application du thème...', 'info');
  google.script.run
    .withSuccessHandler(function(result) {
      if (result.success) {
        USER_PREFERENCES.theme = themeName;
        applyThemeColors(themeName);
        showToast('Thème mis à jour !', 'success');
        updateProfileModal();
      } else { showToast('Erreur: ' + result.error, 'error'); }
    })
    .withFailureHandler(function(error) { showToast('Erreur: ' + error.message, 'error'); })
    .updateUserPreferences({ theme: themeName });
}

function toggleFeature(featureName, enabled) {
  const preferences = {};
  preferences[featureName] = enabled;
  showToast('Sauvegarde...', 'info');
  google.script.run
    .withSuccessHandler(function(result) {
      if (result.success) {
        USER_PREFERENCES[featureName] = enabled;
        applyFeatureVisibility();
        showToast('Préférence mise à jour !', 'success');
      } else {
        const toggleId = 'toggle-' + featureName.replace('Modal','').replace('Function','').toLowerCase();
        const toggle = document.getElementById(toggleId);
        if (toggle) toggle.checked = !enabled;
        showToast('Erreur: ' + result.error, 'error');
      }
    })
    .withFailureHandler(function(error) {
      const toggleId = 'toggle-' + featureName.replace('Modal','').replace('Function','').toLowerCase();
      const toggle = document.getElementById(toggleId);
      if (toggle) toggle.checked = !enabled;
      showToast('Erreur: ' + error.message, 'error');
    })
    .updateUserPreferences(preferences);
}

function updateProfileModal() {
  const nameDisplay  = document.getElementById('profile-name-display');
  const emailDisplay = document.getElementById('profile-email-display');
  if (nameDisplay)  nameDisplay.textContent  = USER_FIRST_NAME;
  if (emailDisplay) emailDisplay.textContent = USER_EMAIL;

  document.querySelectorAll('.rating-scale-btn').forEach(btn => {
    btn.classList.toggle('active', btn.dataset.scale === USER_PREFERENCES.ratingScale);
  });

  const halfPointsToggle = document.getElementById('toggle-half-points');
  if (halfPointsToggle) halfPointsToggle.checked = USER_PREFERENCES.halfPoints === true;

  document.querySelectorAll('.theme-option-modal').forEach(option => {
    option.classList.toggle('active', option.dataset.theme === USER_PREFERENCES.theme);
  });

  const capucinesToggle = document.getElementById('toggle-capucines');
  if (capucinesToggle) capucinesToggle.checked = USER_PREFERENCES.capucines === true;

  const storyToggle  = document.getElementById('toggle-story');
  const shareToggle  = document.getElementById('toggle-share');
  const rewindToggle = document.getElementById('toggle-rewind');
  if (storyToggle)  storyToggle.checked  = USER_PREFERENCES.storyModal  === true;
  if (shareToggle)  shareToggle.checked  = USER_PREFERENCES.shareFunction === true;
  if (rewindToggle) rewindToggle.checked = USER_PREFERENCES.rewind === true;
}

function applyFeatureVisibility() {
  const capPill = document.querySelector('.capucines-pill-wrapper');
  if (capPill) capPill.style.display = (USER_PREFERENCES.capucines === true) ? 'inline-flex' : 'none';
  const storyButton = document.getElementById('story-button-header');
  if (storyButton) storyButton.style.display = (USER_PREFERENCES.storyModal === true) ? 'flex' : 'none';
  const rewindTab  = document.getElementById('nav-rewind');
  if (rewindTab)  rewindTab.style.display  = (USER_PREFERENCES.rewind === true) ? '' : 'none';
  const shareTab   = document.getElementById('nav-share');
  if (shareTab)   shareTab.style.display   = (USER_PREFERENCES.shareFunction === true) ? '' : 'none';
}

function changeRatingScale(scale) {
  showToast('Changement de l\'échelle...', 'info');
  google.script.run
    .withSuccessHandler(function(result) {
      if (result.success) {
        USER_PREFERENCES.ratingScale = scale;
        if (typeof RATING_SCALE !== 'undefined') window.RATING_SCALE = parseInt(scale);
        updateProfileModal();
        showToast('Échelle mise à jour !', 'success');
      } else { showToast('Erreur: ' + result.error, 'error'); updateProfileModal(); }
    })
    .withFailureHandler(function(error) { showToast('Erreur: ' + error.message, 'error'); updateProfileModal(); })
    .updateUserPreferences({ ratingScale: scale });
}

function toggleRatingOption(optionName, enabled) {
  const preferences = {};
  preferences[optionName] = enabled;
  showToast('Sauvegarde...', 'info');
  google.script.run
    .withSuccessHandler(function(result) {
      if (result.success) {
        USER_PREFERENCES[optionName] = enabled;
        if (optionName === 'halfPoints') { window.ALLOW_HALF_POINTS = enabled; window.RATING_STEP = enabled ? 0.5 : 1; }
        updateProfileModal();
        showToast('Préférence mise à jour !', 'success');
      } else {
        const toggle = document.getElementById('toggle-half-points');
        if (toggle) toggle.checked = !enabled;
        showToast('Erreur: ' + result.error, 'error');
      }
    })
    .withFailureHandler(function(error) {
      const toggle = document.getElementById('toggle-half-points');
      if (toggle) toggle.checked = !enabled;
      showToast('Erreur: ' + error.message, 'error');
    })
    .updateUserPreferences(preferences);
}

function confirmDeleteAccount() {
  const confirmModal = document.createElement('div');
  confirmModal.className = 'confirmation-modal';
  confirmModal.innerHTML = `
    <div class="modal-content" style="max-width:360px;">
      <h3 style="color:#ef4444;">⚠️ Supprimer le compte</h3>
      <p style="text-align:left;margin-bottom:15px;">Cette action est <strong>irréversible</strong>.</p>
      <div class="modal-buttons">
        <button onclick="this.closest('.confirmation-modal').remove()">Annuler</button>
        <button style="background:#ef4444;color:white;" onclick="deleteAccount()">Supprimer</button>
      </div>
    </div>`;
  document.body.appendChild(confirmModal);
}

function deleteAccount() {
  document.querySelector('.confirmation-modal')?.remove();
  showToast('Suppression du compte...', 'info');
  google.script.run
    .withSuccessHandler(function(result) {
      if (result.success) {
        showToast('Compte supprimé. Redirection...', 'success');
        closeProfileModal();
        setTimeout(() => window.location.reload(), 2000);
      } else { showToast('Erreur: ' + result.error, 'error'); }
    })
    .withFailureHandler(function(error) { showToast('Erreur: ' + error.message, 'error'); })
    .deleteUserAccount();
}

function syncUserToTracking() {
  const btn = document.querySelector('.sync-user-btn');
  if (btn) btn.classList.add('syncing');
  showToast('Synchronisation du compte...', 'info');
  google.script.run
    .withSuccessHandler(function(result) {
      if (btn) btn.classList.remove('syncing');
      if (result.success) { showToast(result.message || 'Compte synchronisé !', 'success'); }
      else { showToast('Erreur: ' + result.error, 'error'); }
    })
    .withFailureHandler(function(error) {
      if (btn) btn.classList.remove('syncing');
      showToast('Erreur: ' + error.message, 'error');
    })
    .syncUserToTrackingSheet();
}

/* ── Story ── */
function setExcitementLevel(level) {
  const fill    = document.querySelector('.story-expectation-bar .story-gauge-fill');
  const labels  = document.querySelectorAll('.story-expectation-bar .story-gauge-label');
  const labelEl = document.getElementById('story-excitement-label');
  const widths  = { 'very-low':'10%', 'low':'30%', 'moderate':'50%', 'moderate-plus':'75%', 'extreme':'100%' };
  const texts   = { 'very-low':"j'y vais à reculons", 'low':'je le fais pour vous', 'moderate':'et pourquoi pas ?', 'moderate-plus':'je suis impatient !', 'extreme':'je suis au-delà de hypé !' };
  if (fill) fill.style.width = widths[level] || '50%';
  labels.forEach(l => l.classList.toggle('active', l.dataset.level === level));
  if (labelEl) { labelEl.textContent = texts[level] || ''; labelEl.classList.toggle('visible', !!texts[level]); }
}

function scaleStoryCanvas() {
  const wrapper = document.querySelector('.story-canvas-wrapper');
  const canvas  = document.querySelector('.instagram-story-container');
  if (!wrapper || !canvas) return;
  const scale   = Math.min(wrapper.clientWidth / 1080, wrapper.clientHeight / 1920);
  const offsetX = (wrapper.clientWidth  - 1080 * scale) / 2;
  const offsetY = (wrapper.clientHeight - 1920 * scale) / 2;
  canvas.style.transform = 'translate(' + offsetX + 'px,' + offsetY + 'px) scale(' + scale + ')';
}

function openStoryModal() {
  const modal = document.getElementById('story-modal');
  if (!modal) return;
  if (currentFilm) {
    populateStoryModal({ title: currentFilm.titre, poster: currentFilm.affiche, date: currentFilm.date, duration: currentFilm.duree, language: currentFilm.langue, number: nextScreeningNumber });
  } else { populateStoryModal(null); }
  modal.classList.add('active');
  document.body.style.overflow = 'hidden';
  requestAnimationFrame(() => requestAnimationFrame(scaleStoryCanvas));
}

function closeStoryModal() {
  const modal = document.getElementById('story-modal');
  if (!modal) return;
  modal.classList.remove('active');
  document.body.style.overflow = '';
}

function populateStoryModal(film) {
  if (!film) return;
  const posterEl = document.getElementById('story-poster-main');
  if (posterEl && film.poster) { posterEl.src = film.poster; posterEl.onerror = function() { this.src = 'https://placehold.co/1080x1920/7E0000/FD2323?text=🎬'; }; }
  const pillEl  = document.getElementById('story-screening-pill');
  if (pillEl)  pillEl.textContent  = film.number ? '#' + film.number : '#—';
  const titleEl = document.getElementById('story-movie-title');
  if (titleEl) titleEl.textContent = film.title || 'titre du film';
  const dateEl  = document.getElementById('story-date-pill');
  if (dateEl)  dateEl.textContent  = film.date  || '—';
  const timeEl  = document.getElementById('story-time-pill');
  if (timeEl && film.duration) {
    let dur = String(film.duration).trim();
    if (/^\d+$/.test(dur)) { const mins = parseInt(dur,10); const h = Math.floor(mins/60); const m = mins%60; dur = h > 0 ? h+'h'+m.toString().padStart(2,'0') : m+'min'; }
    timeEl.textContent = dur;
  }
  const langEl  = document.getElementById('story-language-pill');
  if (langEl)  langEl.textContent  = (film.language || film.lang || 'VO').toUpperCase();
  const bottomTitle = document.getElementById('story-bottom-title');
  if (bottomTitle) bottomTitle.textContent = film.title || 'La séance du jour';
  setExcitementLevel('moderate');
}

function downloadStory() {
  const btn = document.getElementById('story-download-btn');
  if (btn) { btn.disabled = true; btn.classList.add('story-dl-busy'); }
  if (typeof captureAndDownload === 'function') {
    captureAndDownload('story-capture','story','seance','story-download-btn')
      .finally(() => { if (btn) { btn.disabled = false; btn.classList.remove('story-dl-busy'); } });
  } else { if (btn) { btn.disabled = false; btn.classList.remove('story-dl-busy'); } }
}

window.addEventListener('resize', scaleStoryCanvas);
</script>

<? if (userPreferences.storyModal !== false) { ?>
<div id="story-modal" class="story-modal">
  <button class="story-modal-close-btn" onclick="closeStoryModal()" aria-label="Fermer">×</button>
  <div class="story-post-card">
    <div class="story-canvas-wrapper">
      <div id="story-scale-wrapper">
        <div class="instagram-story-container" id="story-capture">
          <img id="story-poster-main" class="story-poster-bg" src="https://placehold.co/1080x1920/7E0000/FD2323" alt="Movie poster"/>
          <img class="story-logo-img" src="https://i.imgur.com/U6QbyJG.png" alt="Grand Ecran logo"/>
          <div class="story-screening-details">
            <div class="story-movie-title-container">
              <div class="story-screening-number-badge"><span id="story-screening-pill" class="story-screening-number-text">#XX</span></div>
              <span id="story-movie-title" class="story-movie-title-text">titre du film</span>
            </div>
            <div class="story-movie-details-container">
              <div class="story-detail-pill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/></svg><span id="story-date-pill" class="story-detail-text">xx/xx/xxxx</span></div>
              <div class="story-detail-pill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 6v6l4 2"/></svg><span id="story-time-pill" class="story-detail-text">xhxx</span></div>
              <div class="story-detail-pill"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg><span id="story-language-pill" class="story-detail-text">LANG</span></div>
            </div>
            <div class="story-expectation-container">
              <div class="story-expectation-title">mon niveau d'attente :<span id="story-excitement-label" class="story-excitement-label"></span></div>
              <div class="story-expectation-bar">
                <div class="story-gauge-fill"></div>
                <div class="story-gauge-labels">
                  <span class="story-gauge-label" data-level="very-low">😴</span>
                  <span class="story-gauge-label" data-level="low">😐</span>
                  <span class="story-gauge-label active" data-level="moderate">🙂</span>
                  <span class="story-gauge-label" data-level="moderate-plus">😃</span>
                  <span class="story-gauge-label" data-level="extreme">🤩</span>
                </div>
                <div class="story-gauge-checkpoints">
                  <button class="story-checkpoint" onclick="setExcitementLevel('very-low')"></button>
                  <button class="story-checkpoint" onclick="setExcitementLevel('low')"></button>
                  <button class="story-checkpoint" onclick="setExcitementLevel('moderate')"></button>
                  <button class="story-checkpoint" onclick="setExcitementLevel('moderate-plus')"></button>
                  <button class="story-checkpoint" onclick="setExcitementLevel('extreme')"></button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="story-post-bottom">
      <div class="story-bottom-label">Story Instagram</div>
      <div class="story-post-meta">
        <div class="story-post-text">
          <div class="story-post-title" id="story-bottom-title">La séance du jour</div>
          <div class="story-post-desc" id="story-bottom-desc">Ajuste ton niveau d'attente avant de partager</div>
          <div class="story-post-tags">#grandecran #cinema #seance</div>
        </div>
        <button class="story-dl-btn" id="story-download-btn" onclick="downloadStory()" aria-label="Télécharger la story">
          <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        </button>
      </div>
    </div>
  </div>
</div>
<? } ?>

