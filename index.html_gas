<!DOCTYPE html>
<html lang="fr">
<head>

  <!-- ══════════════════════════════════════════════
       BLOC 1 — SYNCHRONE, EN TOUT PREMIER
       Fond noir + safe areas + GAS_READY (envoi 1/3)
  ══════════════════════════════════════════════ -->
  <script>
    (function() {
      // Fond noir immédiat
      document.documentElement.style.background = '#000000';

      // Safe areas initialisées à 0
      document.documentElement.style.setProperty('--safe-top',    '0px');
      document.documentElement.style.setProperty('--safe-bottom', '0px');
      document.documentElement.style.setProperty('--safe-left',   '0px');
      document.documentElement.style.setProperty('--safe-right',  '0px');

      // Écoute des safe areas du wrapper PWA
      window.addEventListener('message', function(event) {
        if (!event.data || event.data.type !== 'GRAND_ECRAN_SAFE_AREAS') return;
        var r = document.documentElement;
        r.style.setProperty('--safe-top',    (event.data.top    || 0) + 'px');
        r.style.setProperty('--safe-bottom', (event.data.bottom || 0) + 'px');
        r.style.setProperty('--safe-left',   (event.data.left   || 0) + 'px');
        r.style.setProperty('--safe-right',  (event.data.right  || 0) + 'px');
        document.documentElement.style.background = '#000000';
        if (document.body) document.body.style.background = '#000000';
      });

      // GAS_READY — envoi 1/3 (immédiat)
      try { window.parent.postMessage({ type: 'GAS_READY' }, '*'); } catch(e) {}

    })();
  </script>

  <!-- ══════════════════════════════════════════════
       BLOC 2 — FONTS
  ══════════════════════════════════════════════ -->
  <link href="https://fonts.googleapis.com/css2?family=Montserrat+Alternates:wght@800&family=Ms+Madi&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@200;400;700;800&display=swap" rel="stylesheet">

  <!-- ══════════════════════════════════════════════
       BLOC 3 — VARIABLES UTILISATEUR
       ⚠️ Déclarées avec VAR, UNE SEULE FOIS dans tout le fichier
       Toute autre occurrence de USER_FIRST_NAME / USER_EMAIL
       dans les scripts plus bas a été SUPPRIMÉE
  ══════════════════════════════════════════════ -->
  <script>
    var USER_FIRST_NAME = '<?= userFirstName ?>';
    var USER_EMAIL      = '<?= userEmail ?>';

    // GAS_READY — envoi 2/3 (après parsing du head)
    try { window.parent.postMessage({ type: 'GAS_READY' }, '*'); } catch(e) {}
  </script>

  <!-- ══════════════════════════════════════════════
       BLOC 4 — PRÉFÉRENCES UTILISATEUR + THÈMES
  ══════════════════════════════════════════════ -->
  <script>
const USER_PREFERENCES = (() => {
  try {
    const prefsString = '<?= userPreferences ?>';
    const parsed = JSON.parse(prefsString);
    return {
      rating:        parsed.rating !== false,
      history:       parsed.history !== false,
      dashboard:     parsed.dashboard !== false,
      storyModal:    parsed.storyModal    === true || parsed.storyModal    === 'true',
      shareFunction: parsed.shareFunction === true || parsed.shareFunction === 'true',
      rewind:        parsed.rewind        === true || parsed.rewind        === 'true',
      theme:         parsed.theme || 'dark-grey',
      ratingScale:   String(parsed.ratingScale || '5'),
      halfPoints:    parsed.halfPoints === true || parsed.halfPoints === 'true',
      capucines:     parsed.capucines  === true || parsed.capucines  === 'true',
    };
  } catch (e) {
    console.error('ERROR parsing preferences:', e);
    return {
      rating: true, history: true, dashboard: true,
      storyModal: false, shareFunction: false, rewind: false,
      theme: 'dark-grey', ratingScale: '5', halfPoints: false, capucines: false,
    };
  }
})();

